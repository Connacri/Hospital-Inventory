name: Full Build & Release

on:
  push:
    branches: [ master ]
    paths-ignore:
      - 'release.json'   # Anti-boucle infinie sur le commit du JSON

permissions:
  contents: write

jobs:
  # ══════════════════════════════════════════════
  # JOB 1 — Android : APK + QR code + Release
  # ══════════════════════════════════════════════
  build-android:
    runs-on: ubuntu-latest
    outputs:
      tag_name:    ${{ steps.versioning.outputs.tag_name }}
      app_version: ${{ steps.versioning.outputs.app_version }}
      apk_url:     ${{ steps.get_apk_url.outputs.apk_url }}

    steps:
      - name: Checkout code
        uses: actions/checkout@v4
        with:
          fetch-depth: 0   # Nécessaire pour git tag --sort

      - name: Setup Flutter
        uses: subosito/flutter-action@v2
        with:
          flutter-version: '3.38.5'
          channel: stable
          cache: true

      - name: Cache Pub & Gradle
        uses: actions/cache@v4
        with:
          path: |
            ~/.pub-cache
            ~/.gradle/caches
          key: ${{ runner.os }}-flutter-${{ hashFiles('**/pubspec.lock') }}
          restore-keys: ${{ runner.os }}-flutter-

      - name: Install Flutter dependencies
        run: flutter pub get

      # ── Calcul du tag (incrémente le build number du dernier tag git)
      - name: Compute versioning
        id: versioning
        run: |
          git fetch --tags --force
          TAG=$(git tag --sort=-v:refname | head -n 1)
          echo "Dernier tag: $TAG"

          if [[ -z "$TAG" ]]; then
            NEW_TAG="v1.0.0+1"
          elif [[ "$TAG" =~ ^v[0-9]+\.[0-9]+\.[0-9]+\+[0-9]+$ ]]; then
            BASE=$(echo "$TAG" | cut -d+ -f1)
            BUILD=$(echo "$TAG" | cut -d+ -f2)
            NEW_TAG="${BASE}+$((BUILD + 1))"
          else
            echo "⚠️ Format de tag invalide — fallback v1.0.0+1"
            NEW_TAG="v1.0.0+1"
          fi

          # Version semver seule (ex: 1.2.3), sans le +buildNumber
          SEMVER=$(echo "$NEW_TAG" | sed 's/^v//' | cut -d+ -f1)

          echo "tag_name=$NEW_TAG"    >> $GITHUB_OUTPUT
          echo "app_version=$SEMVER"  >> $GITHUB_OUTPUT
          echo "✅ Nouveau tag: $NEW_TAG | Version: $SEMVER"

      - name: Build APK release
        run: flutter build apk --release

      - name: Install qrencode
        run: sudo apt-get update -qq && sudo apt-get install -y qrencode

      # ── Génère le QR pointant vers l'APK de cette release
      - name: Prepare APK + QR code
        run: |
          mkdir -p output
          APK_FILENAME="app-${{ steps.versioning.outputs.tag_name }}.apk"
          RELEASE_URL="https://github.com/${{ github.repository }}/releases/latest/download/${APK_FILENAME}"

          cp build/app/outputs/flutter-apk/app-release.apk "output/${APK_FILENAME}"
          qrencode -o "output/qr-${{ steps.versioning.outputs.tag_name }}.png" "$RELEASE_URL"

          echo "APK_FILENAME=${APK_FILENAME}" >> $GITHUB_ENV
          echo "QR : $RELEASE_URL"

      # ── Crée la release GitHub et upload APK + QR
      - name: Create GitHub Release with APK & QR
        uses: softprops/action-gh-release@v2
        with:
          tag_name: ${{ steps.versioning.outputs.tag_name }}
          name: "Release ${{ steps.versioning.outputs.tag_name }}"
          files: |
            output/${{ env.APK_FILENAME }}
            output/qr-${{ steps.versioning.outputs.tag_name }}.png
        env:
          GITHUB_TOKEN: ${{ secrets.MY_PAT }}

      # ── Petite pause pour que l'API GitHub indexe les assets
      - name: Wait for asset indexing
        run: sleep 12

      # ── Récupère l'URL publique de l'APK et l'expose comme output du job
      - name: Get APK download URL
        id: get_apk_url
        run: |
          RESPONSE=$(curl -s \
            -H "Authorization: token ${{ secrets.MY_PAT }}" \
            "https://api.github.com/repos/${{ github.repository }}/releases/tags/${{ steps.versioning.outputs.tag_name }}")

          APK_URL=$(echo "$RESPONSE" | jq -r '.assets[] | select(.name | endswith(".apk")) | .browser_download_url')

          if [[ -z "$APK_URL" ]]; then
            echo "❌ APK URL introuvable dans la release"
            exit 1
          fi

          echo "apk_url=$APK_URL" >> $GITHUB_OUTPUT
          echo "✅ APK URL: $APK_URL"

  # ══════════════════════════════════════════════
  # JOB 2 — Windows : Build + Inno Setup + Upload
  # ══════════════════════════════════════════════
  build-windows:
    runs-on: windows-latest
    needs: build-android
    outputs:
      win_url: ${{ steps.get_win_url.outputs.win_url }}

    steps:
      - name: Checkout code
        uses: actions/checkout@v4

      - name: Setup Flutter
        uses: subosito/flutter-action@v2
        with:
          flutter-version: '3.38.5'
          channel: stable
          cache: true

      - name: Install Flutter dependencies
        run: flutter pub get

      - name: Build Windows release
        run: flutter build windows --release

      # ── Nom de l'exe = name dans pubspec.yaml (ex: my_app → my_app.exe)
      - name: Extract app name from pubspec
        id: get_appname
        shell: bash
        run: |
          APP_NAME=$(grep '^name:' pubspec.yaml | sed 's/name: //' | tr -d '[:space:]')
          echo "app_name=$APP_NAME" >> $GITHUB_OUTPUT
          echo "✅ app_name: $APP_NAME"

      - name: Install Inno Setup
        run: choco install innosetup -y

      # ── Injecte AppName et AppVersion dans setup.iss via /D
      #    Ton setup.iss doit déclarer :
      #      #ifndef AppName
      #        #define AppName "mon_app"
      #      #endif
      #      #ifndef AppVersion
      #        #define AppVersion "1.0.0"
      #      #endif
      - name: Build installer with Inno Setup
        run: |
          iscc installer/setup.iss `
            /DAppName="${{ steps.get_appname.outputs.app_name }}" `
            /DAppVersion="${{ needs.build-android.outputs.app_version }}"

      # ── Upload l'installer sur la release déjà créée par le job Android
      - name: Upload Windows installer to release
        uses: softprops/action-gh-release@v2
        with:
          tag_name: ${{ needs.build-android.outputs.tag_name }}
          files: installer/output/*.exe
        env:
          GITHUB_TOKEN: ${{ secrets.MY_PAT }}

      - name: Wait for Windows asset indexing
        run: Start-Sleep -Seconds 12
        shell: pwsh

      - name: Get Windows installer URL
        id: get_win_url
        shell: bash
        run: |
          RESPONSE=$(curl -s \
            -H "Authorization: token ${{ secrets.MY_PAT }}" \
            "https://api.github.com/repos/${{ github.repository }}/releases/tags/${{ needs.build-android.outputs.tag_name }}")

          WIN_URL=$(echo "$RESPONSE" | jq -r '.assets[] | select(.name | endswith(".exe")) | .browser_download_url')

          if [[ -z "$WIN_URL" ]]; then
            echo "❌ Windows URL introuvable dans la release"
            exit 1
          fi

          echo "win_url=$WIN_URL" >> $GITHUB_OUTPUT
          echo "✅ Windows URL: $WIN_URL"

  # ══════════════════════════════════════════════
  # JOB 3 — Génère et commit release.json
  # ══════════════════════════════════════════════
  update-json:
    runs-on: ubuntu-latest
    needs: [build-android, build-windows]

    steps:
      - name: Checkout code
        uses: actions/checkout@v4
        with:
          token: ${{ secrets.MY_PAT }}

     - name: Generate release.json
        run: |
          cat > release.json << EOF
          {
            "version": "${{ needs.build-android.outputs.app_version }}",
            "tag": "${{ needs.build-android.outputs.tag_name }}",
            "released_at": "$(date -u +%Y-%m-%dT%H:%M:%SZ)",
            "apk_url": "${{ needs.build-android.outputs.apk_url }}",
            "windows_url": "${{ needs.build-windows.outputs.win_url }}",
            "platforms": {
              "android": {
                "url": "${{ needs.build-android.outputs.apk_url }}",
                "mandatory": false
              },
              "windows": {
                "url": "${{ needs.build-windows.outputs.win_url }}",
                "mandatory": false
              }
            }
          }
          EOF
          echo "── release.json généré ──"
          cat release.json

      # [skip ci] empêche ce commit de re-déclencher le workflow
      - name: Commit and push release.json
        run: |
          git config --global user.name  "github-actions[bot]"
          git config --global user.email "github-actions[bot]@users.noreply.github.com"
          git add release.json
          git commit -m "chore: release.json → ${{ needs.build-android.outputs.tag_name }} [skip ci]" \
            || echo "Aucun changement à committer"
          git push
